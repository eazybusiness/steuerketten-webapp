---
// VehicleLayout.astro — Layout für Fahrzeug-Detailseiten
import BaseLayout from './BaseLayout.astro';
import { SITE_CONFIG } from '../content/config.ts';
import MotorTable from '../components/vehicle/MotorTable.astro';
import FAQSection from '../components/seo/FAQSection.astro';
import AnkaufCTA from '../components/vehicle/AnkaufCTA.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import { marked } from 'marked';

export interface Props {
  vehicle: {
    id: string;
    marke: string;
    modell: string;
    slug: string;
    generation: string;
    steuertrieb: string;
    motoren: Array<{
      bezeichnung: string;
      code: string;
      leistung: string;
      bauzeit: string;
      steuertrieb: string;
      intervall: string;
    }>;
    artikel?: {
      slug: string;
      markdown: string;
      quelle: string;
    } | null;
    faq: Array<{
      frage: string;
      antwort: string;
      schemaType: string;
    }>;
    meta: {
      letzteAktualisierung: string;
    };
  };
}

const { vehicle } = Astro.props;

const fullName = `${vehicle.marke} ${vehicle.modell} ${vehicle.generation}`.trim();
const title = `${fullName} – Steuerkette oder Zahnriemen?`;
const description = vehicle.artikel
  ? `Experten-Artikel: ${fullName} hat ${vehicle.steuertrieb}. Alle Motorvarianten mit Steuertrieb-Details.`
  : `${fullName} hat ${vehicle.steuertrieb}. Alle Motorvarianten im Überblick.`;

// Artikel-Markdown zu HTML konvertieren
const artikelHtml = vehicle.artikel ? marked(vehicle.artikel.markdown) : null;

// Schema.org: Vehicle + FAQPage
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Vehicle",
      "name": fullName,
      "brand": {
        "@type": "Brand",
        "name": vehicle.marke
      },
      "model": vehicle.modell,
      "vehicleEngine": vehicle.motoren.map(m => ({
        "@type": "EngineSpecification",
        "name": m.bezeichnung,
        "engineType": m.steuertrieb === 'Steuerkette' ? 'Steuerkette' : 'Zahnriemen'
      }))
    },
    {
      "@type": "FAQPage",
      "mainEntity": vehicle.faq.map(f => ({
        "@type": "Question",
        "name": f.frage,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.antwort
        }
      }))
    }
  ]
};

// Breadcrumb-Schema
const breadcrumbs = [
  { name: 'Start', url: '/' },
  { name: 'Marken', url: '/marke/' },
  { name: vehicle.marke, url: `/marke/${vehicle.marke.toLowerCase()}/` },
  { name: fullName, url: Astro.url.pathname },
];
---

<BaseLayout {title} {description} {schema}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Breadcrumbs -->
    <Breadcrumbs items={breadcrumbs} />
    
    <!-- Hero: Sofort-Antwort -->
    <section class="bg-white rounded-2xl shadow-lg p-8 mb-8">
      <div class="text-center">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          {fullName}
        </h1>
        
        <!-- Sofort-Antwort -->
        <div class={`inline-flex items-center space-x-3 px-6 py-4 rounded-xl text-lg font-semibold ${
          vehicle.steuertrieb === 'Steuerkette' 
            ? 'bg-green-100 text-green-800' 
            : vehicle.steuertrieb === 'Zahnriemen'
              ? 'bg-blue-100 text-blue-800'
              : 'bg-yellow-100 text-yellow-800'
        }`}>
          <span class="text-2xl">
            {vehicle.steuertrieb === 'Steuerkette' ? '⛓️' : vehicle.steuertrieb === 'Zahnriemen' ? '⚙️' : '⚡'}
          </span>
          <span>
            {vehicle.steuertrieb === 'Beides (je nach Motor)' 
              ? 'Steuerkette oder Zahnriemen (je nach Motor)'
              : vehicle.steuertrieb
            }
          </span>
        </div>
        
        <!-- Motor-Anzahl -->
        {vehicle.motoren.length > 0 && (
          <p class="mt-4 text-sm text-gray-500">
            {vehicle.motoren.length} Motorvarianten
          </p>
        )}
      </div>
    </section>
    
    <!-- Experten-Artikel (nur wenn vorhanden) -->
    {artikelHtml && (
      <section class="bg-white rounded-2xl shadow-lg p-8 mb-8 prose prose-gray max-w-none">
        <div class="not-prose mb-4 flex items-center gap-2">
          <span class="bg-amber-100 text-amber-800 text-xs font-semibold px-2 py-1 rounded">Experten-Artikel</span>
          <span class="text-xs text-gray-400">Quelle: {vehicle.artikel?.quelle}</span>
        </div>
        <div set:html={artikelHtml} />
      </section>
    )}
    
    <!-- Motoren-Tabelle -->
    {vehicle.motoren.length > 0 && (
      <section class="bg-white rounded-2xl shadow-lg p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">
          Alle Motorvarianten
        </h2>
        <MotorTable motoren={vehicle.motoren} />
      </section>
    )}
    
    <!-- Steuerkette vs. Zahnriemen (nur wenn kein Artikel - Artikel hat das schon) -->
    {!artikelHtml && (
      <section class="bg-white rounded-2xl shadow-lg p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">
          Steuerkette vs. Zahnriemen
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="p-4 bg-green-50 rounded-lg">
            <h3 class="font-semibold text-green-800 mb-2">Steuerkette</h3>
            <ul class="text-sm text-green-700 space-y-1">
              <li>✓ Wartungsfrei (theoretisch lebenslang)</li>
              <li>✗ Kann sich längen → Motorschaden-Risiko</li>
              <li>✗ Rasselgeräusche = Warnsignal</li>
            </ul>
          </div>
          <div class="p-4 bg-blue-50 rounded-lg">
            <h3 class="font-semibold text-blue-800 mb-2">Zahnriemen</h3>
            <ul class="text-sm text-blue-700 space-y-1">
              <li>✓ Leiser, günstiger im Wechsel</li>
              <li>✗ Muss regelmäßig gewechselt werden</li>
              <li>✗ Riss = Motorschaden</li>
            </ul>
          </div>
        </div>
      </section>
    )}
    
    <!-- FAQ -->
    {vehicle.faq.length > 0 && (
      <FAQSection faq={vehicle.faq} />
    )}
    
    <!-- Ankauf CTA -->
    {SITE_CONFIG.ohauto.enabled && (
      <AnkaufCTA 
        modell={vehicle.modell}
        marke={vehicle.marke}
      />
    )}
    
  </div>
</BaseLayout>
