---
// AnkaufCTA.astro — Call-to-Action für ohAuto.de

import { SITE_CONFIG } from '../../content/config.ts';

export interface Props {
  modell: string;
  marke: string;
  motorschaden?: boolean;
  preisMin?: number;
  preisMax?: number;
}

const { 
  modell, 
  marke, 
  motorschaden = false,
  preisMin = 2000,
  preisMax = 15000,
} = Astro.props;

const ohauto = SITE_CONFIG.ohauto;

const ctaVariants = {
  default: {
    title: `${marke} ${modell} verkaufen?`,
    subtitle: 'Faire Preise, kostenlose Abholung',
    button: 'Jetzt Angebot anfordern',
  },
  motorschaden: {
    title: `${marke} ${modell} mit Motorschaden?`,
    subtitle: 'Wir kaufen auch Fahrzeuge mit Problemen',
    button: 'Angebot für Schadenfahrzeug',
  },
};

const variant = motorschaden ? ctaVariants.motorschaden : ctaVariants.default;
---

<section class="bg-gradient-to-r from-blue-600 to-blue-700 rounded-2xl shadow-lg p-8 text-white">
  <div class="flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="flex-1">
      <h2 class="text-2xl font-bold mb-2">
        {variant.title}
      </h2>
      <p class="text-blue-100 mb-4">
        {variant.subtitle}
      </p>
      <div class="text-sm text-blue-200">
        Preisspanne: {preisMin.toLocaleString('de-DE')}–{preisMax.toLocaleString('de-DE')} €
        {motorschaden && <span class="ml-2">(je nach Zustand)</span>}
      </div>
    </div>
    
    <div class="flex-shrink-0">
      <a 
        href={ohauto.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center px-6 py-3 bg-white text-blue-600 font-semibold rounded-lg hover:bg-blue-50 transition-colors shadow-md"
      >
        {variant.button}
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      </a>
    </div>
  </div>
  
  <!-- Trust Signals -->
  <div class="mt-6 pt-6 border-t border-blue-500 flex flex-wrap gap-4 text-sm text-blue-100">
    <span class="inline-flex items-center">
      <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
      </svg>
      Kostenlose Abholung
    </span>
    <span class="inline-flex items-center">
      <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
      </svg>
      Sofortzahlung
    </span>
    <span class="inline-flex items-center">
      <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
      </svg>
      5 Tage Preisgarantie
    </span>
  </div>
</section>
