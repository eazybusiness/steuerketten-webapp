---
// MotorTable.astro — Tabelle mit Motorvarianten (nur echte Daten)

export interface Props {
  motoren: Array<{
    bezeichnung: string;
    code: string;
    leistung: string;
    bauzeit: string;
    steuertrieb: string;
    intervall: string;
  }>;
}

const { motoren } = Astro.props;

function getSteuertriebBadge(steuertrieb: string) {
  if (steuertrieb === 'Steuerkette') {
    return { class: 'bg-green-100 text-green-800', icon: '⛓️' };
  }
  if (steuertrieb === 'Zahnriemen') {
    return { class: 'bg-blue-100 text-blue-800', icon: '⚙️' };
  }
  return { class: 'bg-gray-100 text-gray-800', icon: '❓' };
}
---

<div class="overflow-x-auto">
  <table class="w-full text-left">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="px-4 py-3 text-sm font-semibold text-gray-900">Motor</th>
        <th class="px-4 py-3 text-sm font-semibold text-gray-900">Leistung</th>
        <th class="px-4 py-3 text-sm font-semibold text-gray-900">Bauzeit</th>
        <th class="px-4 py-3 text-sm font-semibold text-gray-900">Steuertrieb</th>
        <th class="px-4 py-3 text-sm font-semibold text-gray-900">Intervall</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      {motoren.map((motor, index) => {
        const badge = getSteuertriebBadge(motor.steuertrieb);
        return (
          <tr class={index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
            <td class="px-4 py-3">
              <div class="font-medium text-gray-900">{motor.bezeichnung}</div>
              {motor.code && (
                <div class="text-xs text-gray-500">Code: {motor.code}</div>
              )}
            </td>
            <td class="px-4 py-3 text-sm text-gray-700">
              {motor.leistung || '–'}
            </td>
            <td class="px-4 py-3 text-sm text-gray-700">
              {motor.bauzeit || '–'}
            </td>
            <td class="px-4 py-3">
              <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${badge.class}`}>
                <span class="mr-1">{badge.icon}</span>
                {motor.steuertrieb}
              </span>
            </td>
            <td class="px-4 py-3 text-sm text-gray-700">
              {motor.intervall || '–'}
            </td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>

<p class="mt-3 text-xs text-gray-400">
  Quelle: autosmotor.de · Angaben ohne Gewähr · Prüfe immer die Betriebsanleitung deines Fahrzeugs
</p>
